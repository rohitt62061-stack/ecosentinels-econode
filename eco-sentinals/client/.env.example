# Supabase connection (get from supabase.com → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# WAQI API for live AQI data (free at aqicn.org/data-platform/token)
VITE_WAQI_TOKEN=your-waqi-token-here

# Anthropic Claude API (console.anthropic.com)
VITE_ANTHROPIC_KEY=your-anthropic-key-here

# Set to 'false' to use Supabase Edge Functions (recommended)
# Set to 'true' only when running Python server locally for hardware testing
VITE_USE_LOCAL_SERVER=false
VITE_LOCAL_SERVER_URL=http://localhost:8000
